#!/bin/bash -e

# Ensure the container always boots with a clean tmp cache and no stale PID files.
# Persistent host-volume mappings can leave root-owned files that crash subsequent boots.
rm -rf tmp/cache/* tmp/pids/server.pid 2>/dev/null || true
mkdir -p tmp/cache tmp/pids tmp/sockets log storage
chmod -R 777 tmp log storage 2>/dev/null || true

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  rm -f tmp/pids/server.pid
fi

exec "${@}"
